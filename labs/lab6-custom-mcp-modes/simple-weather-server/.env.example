# Simple Weather MCP Server Configuration

# OpenWeatherMap API Key (Optional - works in demo mode without it!)
# Get a free API key at: https://openweathermap.org/api
# Sign up is free and takes 2 minutes
OPENWEATHER_API_KEY=your_api_key_here

# Note: If you don't set an API key, the server will run in DEMO mode
# with mock weather data - perfect for testing!